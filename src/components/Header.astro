---
const pathname = Astro.url.pathname;
import SearchModal from './SearchModal.astro';
---
<header class="sticky top-0 z-50 bg-white border-b border-gray-200 h-16 flex items-center justify-between px-6">
  <div class="flex items-center gap-6">
    <a href="/" class="flex items-center gap-2 text-ink no-underline focus-visible:ring-2 focus-visible:ring-black outline-none rounded-sm">
      <img src="/favicon.svg" alt="Latest News Logo" class="h-6 w-6 dark:invert" onerror="this.style.display='none'" />
      <span class="font-sans font-semibold text-lg tracking-tight">Latest News</span>
    </a>
  </div>

  <div class="flex items-center gap-3">
    <button id="theme-toggle" aria-label="Toggle dark mode" class="w-8 h-8 flex items-center justify-center rounded-full border border-gray-200 text-ink hover:bg-gray-50 focus-visible:ring-2 focus-visible:ring-black outline-none">
      <svg id="theme-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
    </button>
    <button id="search-toggle" aria-label="Search articles" class="w-8 h-8 flex items-center justify-center rounded-full border border-gray-200 text-ink hover:bg-gray-50 focus-visible:ring-2 focus-visible:ring-black outline-none">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
    </button>
    <div class="hidden sm:flex items-center gap-2">
      <a href="/faq" class="text-sm font-medium px-3 h-7 flex items-center rounded bg-white text-ink border border-gray-200 hover:bg-gray-50 focus-visible:ring-2 focus-visible:ring-black outline-none">FAQ</a>
      <a href="/about" class="text-sm font-medium px-3 h-7 flex items-center rounded bg-white text-ink border border-gray-200 hover:bg-gray-50 focus-visible:ring-2 focus-visible:ring-black outline-none">About Me</a>
      <a href="/contact" class="text-sm font-medium px-3 h-7 flex items-center rounded bg-black text-white hover:bg-gray-900 focus-visible:ring-2 focus-visible:ring-black focus-visible:ring-offset-2 outline-none">Contact Us</a>
    </div>
  </div>
</header>
<SearchModal />
