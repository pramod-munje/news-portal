---
// src/components/Hero.astro
---
<section class="relative w-full pt-16 pb-12 px-6 overflow-hidden flex flex-col items-center text-center bg-canvas-soft">
  <!-- Vercel-style Mesh Gradient Backdrop -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden flex justify-center">
    <div class="w-[800px] h-[400px] max-w-full opacity-40 blur-[80px]" style="background: radial-gradient(circle at 30% 30%, #50e3c2 0%, transparent 40%), radial-gradient(circle at 70% 30%, #007cf0 0%, transparent 40%), radial-gradient(circle at 50% 70%, #ff0080 0%, transparent 40%), radial-gradient(circle at 80% 80%, #f9cb28 0%, transparent 40%); transform: translate3d(0,0,0);"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto flex flex-col items-center">

    <p class="text-xl md:text-2xl font-medium text-gray-500 dark:text-gray-400 mb-8 tracking-tight">
      One platform, infinite intelligence, zero noise.
    </p>
    
    <h1 class="text-3xl md:text-4xl lg:text-5xl font-medium text-gray-400 dark:text-gray-500 leading-relaxed md:leading-relaxed lg:leading-relaxed tracking-tight text-balance mb-12">
      Latest News aggregates <span class="text-black dark:text-white font-semibold">top-tier sources</span>, deploys <span class="text-black dark:text-white font-semibold">autonomous agents</span> to filter out the noise, and <span class="text-black dark:text-white font-semibold">curates a clean feed</span> to keep you updated — all in real-time.
    </h1>

    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 mb-10 text-sm font-medium">
      <a href="/about" class="text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black rounded-sm">About Us</a>
      <a href="/contact" class="text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black rounded-sm">Contact Us</a>
      <a href="/terms" class="text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black rounded-sm">Terms & Conditions</a>
      <a href="/privacy" class="text-body hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black rounded-sm">Privacy Policy</a>
    </div>
    
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a href="#latest" class="h-12 px-6 rounded-full bg-black text-white font-medium flex items-center hover:bg-gray-900 transition-colors focus-visible:ring-2 focus-visible:ring-black focus-visible:ring-offset-2 outline-none text-base">
        Start Reading
      </a>
      <a href="/about" class="h-12 px-6 rounded-full bg-white text-ink font-medium flex items-center border border-gray-200 hover:bg-gray-50 transition-colors focus-visible:ring-2 focus-visible:ring-black focus-visible:ring-offset-2 outline-none text-base">
        Learn More
      </a>
    </div>
  </div>
</section>
