---
import type { Article } from '../lib/news';

export interface Props {
  article: Article;
  featured?: boolean;
}

const { article, featured = false } = Astro.props;

const dateDisplay = article.pubDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric'
});
const categoryLabel = article.category.replace(/-/g, ' ');
---

<article 
  data-category={article.category}
  class:list={[
  "news-item group relative flex flex-col bg-white rounded-lg shadow-[0_1px_1px_rgba(0,0,0,0.02),_0_2px_2px_rgba(0,0,0,0.04)] ring-1 ring-gray-200 overflow-hidden hover:shadow-[0_2px_2px_rgba(0,0,0,0.04),_0_8px_8px_-8px_rgba(0,0,0,0.04)] transition-shadow",
  featured ? "md:flex-row md:col-span-full" : ""
]}>
  <div class:list={["relative overflow-hidden bg-gray-100", featured ? "md:w-1/2" : "w-full aspect-video"]}>
    <img 
      src={article.image || article.fallbackImage} 
      alt={article.title}
      loading={featured ? "eager" : "lazy"}
      width="800"
      height="450"
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
      onerror={`this.onerror=null; this.src='${article.fallbackImage}';`}
    />
    <div class="absolute top-3 right-3 px-2 py-0.5 rounded-full bg-white/90 backdrop-blur text-[10px] font-mono text-ink font-medium tracking-wide uppercase shadow-sm">
      {categoryLabel}
    </div>
  </div>

  <div class:list={["flex flex-col p-6 min-w-0 flex-1", featured ? "md:w-1/2 md:justify-center md:p-10" : ""]}>
    <div class="flex items-center gap-2 text-xs font-mono text-mute mb-3">
      <span class="font-medium text-body">{article.source}</span>
      <span>•</span>
      <time datetime={article.pubDate.toISOString()}>{dateDisplay}</time>
    </div>
    
    <a href={article.link} target="_blank" rel="noopener noreferrer" class="focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black rounded-sm mb-2 block">
      <h3 class:list={[
        "font-semibold text-ink tracking-tight hover:text-blue-600 transition-colors line-clamp-3 text-balance",
        featured ? "text-2xl" : "text-lg"
      ]}>
        {article.title}
      </h3>
    </a>
    
    <p class="text-body text-sm line-clamp-3 mb-6 flex-1">
      {article.description}
    </p>
    
    <div class="mt-auto">
      <a href={article.link} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-medium text-ink hover:text-blue-600 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black rounded-sm">
        Read Full Article
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</article>
