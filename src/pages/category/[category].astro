---
import '../../styles/global.css';
import Header from '../../components/Header.astro';
import CategoryPills from '../../components/CategoryPills.astro';
import NewsCard from '../../components/NewsCard.astro';
import Footer from '../../components/Footer.astro';
import { fetchNews } from '../../lib/news';

export async function getStaticPaths() {
  const articles = await fetchNews();
  const categories = [...new Set(articles.map((a) => a.category))];
  
  // Define the core categories to ensure pages always generate even if no articles exist right now
  const coreCategories = ['world', 'technology', 'science', 'business', 'startups', 'space'];
  const allCategories = [...new Set([...categories, ...coreCategories])];

  return allCategories.map((category) => {
    return {
      params: { category },
      props: { 
        articles: articles.filter((a) => a.category === category)
      },
    };
  });
}

const { category } = Astro.params;
const { articles } = Astro.props;

const featuredArticle = articles.length > 0 ? articles[0] : null;
const gridArticles = articles.length > 1 ? articles.slice(1) : [];
const categoryLabel = category.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{categoryLabel} News | Latest News</title>
  
  <meta name="description" content={`Latest updates and autonomous news aggregation for ${categoryLabel}.`}>
  <meta name="keywords" content="news, today news, best news, news today, trump news, google news, breaking news, bbc news, world news, latest news, trump news today, ai news, latest ai news, ai news today, ai news anchor, ai news india, anthropic ai news, open ai news, claude ai news, science news, science news today, latest science news, today's science news, science news for students, science news in hindi, python data science news, business news, business news today, space news today, space news, nasa">
  <link rel="icon" type="image/png" href="/favicon-96x96.png?v=2" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
  <meta name="apple-mobile-web-app-title" content="News" />
  <link rel="manifest" href="/site.webmanifest?v=2" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap">
  
  <script is:inline>
    const theme = (() => {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        return 'dark';
      }
      return 'light';
    })();
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  </script>
</head>
<body class="antialiased min-h-screen flex flex-col bg-canvas-soft text-ink">
  <Header />
  
  <main class="flex-1">
    <CategoryPills />
    <section class="max-w-6xl mx-auto px-6 pt-8 pb-16">
      <div class="mb-12 flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-gray-200 pb-8">
        <div>
          <h1 class="text-4xl font-semibold tracking-tight text-ink mb-2">
            {categoryLabel}
          </h1>
          <p class="text-body text-lg">Signal extracted from the noise.</p>
        </div>
        <span class="inline-flex px-3 py-1 bg-gray-100 rounded-full font-mono text-xs text-mute uppercase tracking-wider">{articles.length} items aggregated</span>
      </div>

      {articles.length === 0 ? (
        <div class="p-16 text-center bg-gray-50 rounded-lg border border-gray-200">
          <p class="text-body font-mono text-sm">No {categoryLabel} articles found in the latest aggregation cycle.</p>
          <a href="/" class="inline-block mt-4 text-blue-600 hover:underline">Return to Home</a>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredArticle && <NewsCard article={featuredArticle} featured={true} />}
          {gridArticles.map((article) => (
            <NewsCard article={article} />
          ))}
        </div>
      )}
    </section>
  </main>

  <Footer />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Dark mode toggle
      const themeToggleBtn = document.getElementById('theme-toggle');
      const themeIcon = document.getElementById('theme-icon');
      
      const updateIcon = () => {
        const isDark = document.documentElement.classList.contains('dark');
        if (isDark) {
          themeIcon.innerHTML = '<circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>';
        } else {
          themeIcon.innerHTML = '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>';
        }
      };
      
      updateIcon();

      themeToggleBtn.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        updateIcon();
      });
    });
  </script>
</body>
</html>
