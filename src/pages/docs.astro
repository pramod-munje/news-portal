---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Documentation | Latest News</title>
  
  <meta name="description" content="Documentation and architecture overview for Latest News.">
  <link rel="icon" type="image/png" href="/favicon-96x96.png?v=2" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
  <meta name="apple-mobile-web-app-title" content="News" />
  <link rel="manifest" href="/site.webmanifest?v=2" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap">
  
  <script is:inline>
    const theme = (() => {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        return 'dark';
      }
      return 'light';
    })();
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  </script>
</head>
<body class="antialiased min-h-screen flex flex-col bg-canvas-soft text-ink">
  <Header />
  
  <main class="flex-1 max-w-3xl mx-auto px-6 py-16 w-full">
    <h1 class="text-4xl font-semibold tracking-tight text-ink mb-8">Documentation</h1>
    
    <div class="prose prose-gray dark:prose-invert">
      <p class="text-body mb-6">Welcome to the Latest News documentation.</p>
      
      <h2 class="text-2xl font-semibold text-ink mt-8 mb-4">Architecture Overview</h2>
      <p class="text-body mb-6">Latest News is an autonomous, agentic news aggregation portal. It automatically parses global RSS feeds (including BBC, TechCrunch, Wired, NASA, and Nature), categorizes them intelligently, and displays the most recent 3 days of news.</p>
      
      <h2 class="text-2xl font-semibold text-ink mt-8 mb-4">Data Extraction Engine</h2>
      <p class="text-body mb-6">Our engine deduplicates articles based on URL and Title hashes, normalizes external image URLs to bypass tracker pixels, and statically generates dedicated category routes using the Astro web framework.</p>
      
      <h2 class="text-2xl font-semibold text-ink mt-8 mb-4">Styling and Design</h2>
      <p class="text-body mb-6">The interface uses a minimalist, premium design system inspired by Vercel. It features full native Dark Mode support via CSS variables, automated fallback image generation via SVG, and dynamic typography matching modern design aesthetics.</p>
    </div>
  </main>

  <Footer />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Dark mode toggle
      const themeToggleBtn = document.getElementById('theme-toggle');
      const themeIcon = document.getElementById('theme-icon');
      
      const updateIcon = () => {
        const isDark = document.documentElement.classList.contains('dark');
        if (isDark) {
          themeIcon.innerHTML = '<circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>';
        } else {
          themeIcon.innerHTML = '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>';
        }
      };
      
      updateIcon();

      if(themeToggleBtn) {
        themeToggleBtn.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          updateIcon();
        });
      }
    });
  </script>
</body>
</html>
