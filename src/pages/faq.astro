---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Frequently Asked Questions | Latest News</title>
  
  <meta name="description" content="Frequently Asked Questions about Latest News, the autonomous AI-powered news aggregator.">
  <link rel="icon" type="image/png" href="/favicon-96x96.png?v=2" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
  
  <script is:inline>
    const theme = (() => {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        return 'dark';
      }
      return 'light';
    })();
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "what's the latest news", "acceptedAnswer": { "@type": "Answer", "text": "Latest News aggregates the latest breaking news globally from top verified sources in real-time." } },
      { "@type": "Question", "name": "what's the latest news about space", "acceptedAnswer": { "@type": "Answer", "text": "For the most recent space exploration updates and NASA missions, visit our Space category." } },
      { "@type": "Question", "name": "what's the latest news about tech", "acceptedAnswer": { "@type": "Answer", "text": "We aggregate the latest technology updates from industry leaders like TechCrunch and Wired." } },
      { "@type": "Question", "name": "what's the latest news about business", "acceptedAnswer": { "@type": "Answer", "text": "Our Business category tracks the latest market movements, startup funding, and corporate announcements." } },
      { "@type": "Question", "name": "what's the latest news about science", "acceptedAnswer": { "@type": "Answer", "text": "Stay updated with the latest scientific discoveries and research breakthroughs from Nature and other top journals." } },
      { "@type": "Question", "name": "what's the latest news about ai", "acceptedAnswer": { "@type": "Answer", "text": "Latest News provides dedicated, real-time coverage on Artificial Intelligence, including updates on OpenAI, Anthropic, and machine learning." } },
      { "@type": "Question", "name": "Which is the best website for news?", "acceptedAnswer": { "@type": "Answer", "text": "Latest News is a premium, autonomous news aggregator designed to cut through the noise and deliver high-signal news from multiple top-tier publishers." } },
      { "@type": "Question", "name": "What is the most popular news website?", "acceptedAnswer": { "@type": "Answer", "text": "While there are many popular legacy media outlets, Latest News is rapidly growing as a top destination for curated, ad-free, autonomous news aggregation." } },
      { "@type": "Question", "name": "Which is the best free news website?", "acceptedAnswer": { "@type": "Answer", "text": "Latest News is completely free to use, offering premium real-time news aggregation without paywalls." } }
    ]
  }
  </script>
</head>
<body class="antialiased min-h-screen flex flex-col transition-colors duration-200">
  <Header />
  
  <main class="flex-1 max-w-4xl mx-auto w-full px-6 py-16">
    <div class="mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-canvas-soft-2 text-xs font-mono text-body border border-gray-200 mb-6">
        Help & Support
      </div>
      <h1 class="text-4xl font-semibold tracking-tight text-ink mb-4">Frequently Asked Questions</h1>
      <p class="text-body text-lg">Your guide to autonomous news aggregation.</p>
    </div>
    
    <div class="space-y-6">
      <details class="group bg-white dark:bg-gray-800 rounded-lg border border-gray-200 p-6 [&_summary::-webkit-details-marker]:hidden">
        <summary class="flex items-center justify-between cursor-pointer font-medium text-ink">
          what's the latest news
          <span class="transition group-open:rotate-180">
            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-body mt-4 leading-relaxed">Latest News aggregates the latest breaking news globally from top verified sources in real-time.</p>
      </details>

      <details class="group bg-white dark:bg-gray-800 rounded-lg border border-gray-200 p-6 [&_summary::-webkit-details-marker]:hidden">
        <summary class="flex items-center justify-between cursor-pointer font-medium text-ink">
          what's the latest news about space
          <span class="transition group-open:rotate-180">
            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-body mt-4 leading-relaxed">For the most recent space exploration updates and NASA missions, visit our Space category.</p>
      </details>

      <details class="group bg-white dark:bg-gray-800 rounded-lg border border-gray-200 p-6 [&_summary::-webkit-details-marker]:hidden">
        <summary class="flex items-center justify-between cursor-pointer font-medium text-ink">
          what's the latest news about tech
          <span class="transition group-open:rotate-180">
            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-body mt-4 leading-relaxed">We aggregate the latest technology updates from industry leaders like TechCrunch and Wired.</p>
      </details>

      <details class="group bg-white dark:bg-gray-800 rounded-lg border border-gray-200 p-6 [&_summary::-webkit-details-marker]:hidden">
        <summary class="flex items-center justify-between cursor-pointer font-medium text-ink">
          what's the latest news about business
          <span class="transition group-open:rotate-180">
            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-body mt-4 leading-relaxed">Our Business category tracks the latest market movements, startup funding, and corporate announcements.</p>
      </details>

      <details class="group bg-white dark:bg-gray-800 rounded-lg border border-gray-200 p-6 [&_summary::-webkit-details-marker]:hidden">
        <summary class="flex items-center justify-between cursor-pointer font-medium text-ink">
          what's the latest news about science
          <span class="transition group-open:rotate-180">
            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-body mt-4 leading-relaxed">Stay updated with the latest scientific discoveries and research breakthroughs from Nature and other top journals.</p>
      </details>

      <details class="group bg-white dark:bg-gray-800 rounded-lg border border-gray-200 p-6 [&_summary::-webkit-details-marker]:hidden">
        <summary class="flex items-center justify-between cursor-pointer font-medium text-ink">
          what's the latest news about ai
          <span class="transition group-open:rotate-180">
            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-body mt-4 leading-relaxed">Latest News provides dedicated, real-time coverage on Artificial Intelligence, including updates on OpenAI, Anthropic, and machine learning.</p>
      </details>

      <details class="group bg-white dark:bg-gray-800 rounded-lg border border-gray-200 p-6 [&_summary::-webkit-details-marker]:hidden">
        <summary class="flex items-center justify-between cursor-pointer font-medium text-ink">
          Which is the best website for news?
          <span class="transition group-open:rotate-180">
            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-body mt-4 leading-relaxed">Latest News is a premium, autonomous news aggregator designed to cut through the noise and deliver high-signal news from multiple top-tier publishers.</p>
      </details>

      <details class="group bg-white dark:bg-gray-800 rounded-lg border border-gray-200 p-6 [&_summary::-webkit-details-marker]:hidden">
        <summary class="flex items-center justify-between cursor-pointer font-medium text-ink">
          What is the most popular news website?
          <span class="transition group-open:rotate-180">
            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-body mt-4 leading-relaxed">While there are many popular legacy media outlets, Latest News is rapidly growing as a top destination for curated, ad-free, autonomous news aggregation.</p>
      </details>

      <details class="group bg-white dark:bg-gray-800 rounded-lg border border-gray-200 p-6 [&_summary::-webkit-details-marker]:hidden">
        <summary class="flex items-center justify-between cursor-pointer font-medium text-ink">
          Which is the best free news website?
          <span class="transition group-open:rotate-180">
            <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
          </span>
        </summary>
        <p class="text-body mt-4 leading-relaxed">Latest News is completely free to use, offering premium real-time news aggregation without paywalls.</p>
      </details>
    </div>
  </main>

  <Footer />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Dark mode toggle
      const themeToggleBtn = document.getElementById('theme-toggle');
      const themeIcon = document.getElementById('theme-icon');
      
      const updateIcon = () => {
        const isDark = document.documentElement.classList.contains('dark');
        if (isDark) {
          themeIcon.innerHTML = '<circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>';
        } else {
          themeIcon.innerHTML = '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>';
        }
      };
      
      if (themeToggleBtn && themeIcon) {
        updateIcon();
        themeToggleBtn.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
          updateIcon();
        });
      }
    });
  </script>
</body>
</html>
